{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhengcb81.github.io/invest-skills/schemas/valuation-model-2.0.schema.json",
  "title": "Invest valuation model 2.0",
  "type": "object",
  "required": ["valuation_model_schema_version", "methods", "equity_adjustments", "parameters", "sources", "evidence_claims", "limitations"],
  "properties": {
    "valuation_model_schema_version": {"const": "2.0"},
    "methods": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/method"}},
    "equity_adjustments": {"type": "array", "items": {"type": "object", "required": ["parameter_template"]}},
    "method_weights": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}},
    "security_bridge": {"type": "object"},
    "sensitivity_cases": {"type": "array", "items": {"type": "object"}},
    "reverse_cases": {"type": "array", "items": {"type": "object"}},
    "parameters": {"type": "array", "items": {"type": "object"}},
    "sources": {"type": "array", "items": {"type": "object"}},
    "evidence_claims": {"type": "array", "items": {"type": "object"}},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "method": {
      "type": "object", "required": ["method_id", "type", "value_basis", "valuation_timing"],
      "properties": {
        "method_id": {"type": "string", "minLength": 1}, "type": {"enum": ["dcf", "multiple", "asset"]},
        "value_basis": {"enum": ["enterprise", "equity"]}, "valuation_timing": {"enum": ["current", "exit"]},
        "metric": {"type": "string", "minLength": 1}, "metric_period": {"type": "string", "minLength": 1},
        "cash_flow_basis": {"enum": ["fcff", "fcfe", "dividend", "distributable"]},
        "multiple_kind": {"enum": ["pe", "ps", "ev_sales", "ev_ebitda", "p_ffo", "p_affo", "custom"]},
        "multiple_rationale": {"type": "string", "minLength": 1},
        "expected_metric_dimension": {"type": "string", "minLength": 1}
      },
      "allOf": [{
        "if": {"properties": {"multiple_kind": {"const": "custom"}}, "required": ["multiple_kind"]},
        "then": {"required": ["multiple_rationale", "expected_metric_dimension"]}
      }]
    }
  }
}
