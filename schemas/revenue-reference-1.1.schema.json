{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhengcb81.github.io/invest-skills/schemas/revenue-reference-1.1.schema.json",
  "title": "Immutable revenue forecast reference 1.1",
  "type": "object",
  "required": [
    "revenue_reference_schema_version", "schema_version", "engine_version",
    "input_sha256", "result_sha256", "management_target_coverage_status",
    "management_target_summary", "management_target_summary_sha256",
    "growth_driver_analysis_status", "growth_driver_analysis_sha256",
    "growth_driver_summary", "growth_driver_summary_sha256"
  ],
  "properties": {
    "revenue_reference_schema_version": {"const": "1.1"},
    "schema_version": {"type": "string", "minLength": 1},
    "engine_version": {"type": "string", "minLength": 1},
    "input_sha256": {"$ref": "#/$defs/hash"},
    "result_sha256": {"$ref": "#/$defs/hash"},
    "management_target_coverage_status": {"enum": ["validated", "legacy_measurement_semantics", "legacy_not_available"]},
    "management_target_summary": {"type": "array", "items": {"type": "object"}},
    "management_target_summary_sha256": {"$ref": "#/$defs/hash"},
    "growth_driver_analysis_status": {"enum": ["validated", "data_gap", "legacy_not_available"]},
    "growth_driver_analysis_sha256": {"oneOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]},
    "growth_driver_summary": {
      "type": "object",
      "required": ["drivers", "unattributed_company_adjustments", "reconciliation", "rationale"],
      "properties": {
        "drivers": {"type": "array", "items": {"$ref": "#/$defs/driver"}},
        "unattributed_company_adjustments": {"type": ["number", "null"]},
        "reconciliation": {"type": ["object", "null"]},
        "rationale": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "growth_driver_summary_sha256": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "driver": {
      "type": "object",
      "required": [
        "driver_id", "title", "thesis", "direction", "rank", "parameter_ids",
        "segment_names", "causal_chain", "horizon", "persistence",
        "persistence_rationale", "estimated_base_terminal_increment",
        "share_of_positive_driver_increment", "evidence_status", "leading_indicators",
        "falsifiers", "counterevidence_status", "counterevidence_rationale"
      ],
      "properties": {
        "driver_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "thesis": {"type": "string", "minLength": 1},
        "direction": {"enum": ["growth", "headwind", "flat"]},
        "rank": {"type": ["integer", "null"], "minimum": 1},
        "parameter_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "segment_names": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "causal_chain": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "horizon": {"type": "object", "required": ["start_year", "end_year"], "properties": {"start_year": {"type": "integer"}, "end_year": {"type": "integer"}}, "additionalProperties": false},
        "persistence": {"type": "string", "minLength": 1},
        "persistence_rationale": {"type": "string", "minLength": 1},
        "estimated_base_terminal_increment": {"type": "number"},
        "share_of_positive_driver_increment": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "evidence_status": {"type": "string", "minLength": 1},
        "leading_indicators": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "falsifiers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "counterevidence_status": {"type": "string", "minLength": 1},
        "counterevidence_rationale": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
