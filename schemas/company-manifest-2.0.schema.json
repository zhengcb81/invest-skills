{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhengcb81.github.io/invest-skills/schemas/company-manifest-2.0.schema.json",
  "title": "Invest company orchestration manifest 2.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "identity", "scenario_policy", "required_constraint_ids", "segments", "sotp_model", "bundle_plan"],
  "properties": {
    "manifest_version": {"const": "2.0"},
    "identity": {"type": "object", "required": ["company_name", "as_of_date", "currency", "unit", "fiscal_year_end", "base_year", "forecast_years"]},
    "scenario_policy": {
      "type": "object", "additionalProperties": false, "required": ["scenario_set", "source", "definitions"],
      "properties": {"scenario_set": {"const": ["low", "base", "high"]}, "source": {"type": "string", "minLength": 1}, "definitions": {"type": "object", "required": ["low", "base", "high"]}}
    },
    "required_constraint_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "financial_model", "valuation_model"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "financial_model": {"type": "object"},
          "valuation_model": {"type": "object"}
        }
      }
    },
    "sotp_model": {"type": "object"},
    "supplemental_artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["module", "scope", "artifact_id", "artifact_sha256", "required"]}},
    "bundle_plan": {"type": "object", "required": ["bundle_plan_schema_version", "required_modules", "optional_modules", "required_scoped_artifacts", "optional_scoped_artifacts", "limitations"]}
  }
}
